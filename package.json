{
  "name": "lerntracker",
  "version": "1.0.0",
  "description": "Kawaii Galaxy Lerntracker",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron . --no-sandbox",
    "postinstall": "npm rebuild better-sqlite3 --runtime=electron --target=43.1.0 --dist-url=https://electronjs.org/headers"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tiptap/extension-color": "^3.27.3",
    "@tiptap/extension-font-family": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "build": {
    "appId": "com.emilia.lerntracker",
    "productName": "Lerntracker",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
